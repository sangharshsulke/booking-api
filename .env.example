# ============================================
# Railway automatically sets DATABASE_URL
# when you add the PostgreSQL plugin.
# All other vars must be set manually in Railway dashboard.
# ============================================

# Server
PORT=3000
NODE_ENV=production

# Database (Railway auto-fills this — DO NOT set manually if using Railway Postgres plugin)
DATABASE_URL=

# JWT
JWT_SECRET=your_super_secret_key_here_change_this
JWT_EXPIRE=70d

# Firebase Admin SDK (from serviceAccountKey.json)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
